{
  "expo": {
    "name": "WordWave",
    "slug": "wordwave",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#4CAF50"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.wordwave.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#4CAF50"
      },
      "package": "com.wordwave.app"
    },
    "plugins": ["expo-router"],
    "scheme": "wordwave"
  }
}
