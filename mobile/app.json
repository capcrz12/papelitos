{
  "expo": {
    "name": "QueRule",
    "slug": "QueRule",
    "version": "1.0.0",
    "sdkVersion": "54.0.0",
    "icon": "./assets/Icon-1024.png",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#4CAF50"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.QueRule.app",
      "buildNumber": "1"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/Icon-1024.png",
        "backgroundColor": "#4CAF50"
      },
      "package": "com.QueRule.app",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "plugins": ["expo-router", "expo-audio", "expo-video", "expo-asset"],
    "scheme": "querule",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "fbef9aed-43f0-4fd8-8b06-00da6f02fd65"
      }
    },
    "owner": "cap12"
  }
}
